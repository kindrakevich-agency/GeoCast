# Copy to .env and fill in. Never commit .env.

# RPC endpoints. The public Base ones work but are rate-limited; use
# Alchemy or Infura for anything beyond dev.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Etherscan-compatible API key for Basescan (verify contracts after deploy).
BASESCAN_API_KEY=

# Deployer wallet. Generate a fresh key, fund with ~$5 of Base ETH.
DEPLOYER_PRIVATE_KEY=

# Treasury — receives the 5% rake. Gnosis Safe address in prod;
# can be the deployer's EOA on testnet.
TREASURY_ADDRESS=

# Resolver — calls createRound + resolve. Same key as TREASURY_ADDRESS is
# fine on testnet; multisig in prod.
ADMIN_ADDRESS=
