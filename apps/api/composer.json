{
  "name": "geocast/api",
  "description": "GeoCast Symfony API — SIWE auth, rounds, predictions, scoring, real-time broadcasts.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "api-platform/symfony": "^4.0",
    "doctrine/dbal": "^3",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^3.2",
    "kornrunner/keccak": "^1.1",
    "kornrunner/secp256k1": "^0.3",
    "lexik/jwt-authentication-bundle": "^3.1",
    "nelmio/cors-bundle": "^2.5",
    "predis/predis": "^2.2",
    "pusher/pusher-php-server": "^7.2",
    "symfony/asset": "7.4.*",
    "symfony/console": "7.4.*",
    "symfony/dotenv": "7.4.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "7.4.*",
    "symfony/messenger": "7.4.*",
    "symfony/property-access": "7.4.*",
    "symfony/property-info": "7.4.*",
    "symfony/runtime": "7.4.*",
    "symfony/security-bundle": "7.4.*",
    "symfony/serializer": "7.4.*",
    "symfony/uid": "7.4.*",
    "symfony/validator": "7.4.*",
    "symfony/yaml": "7.4.*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "symfony/maker-bundle": "^1.60"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  }
}
