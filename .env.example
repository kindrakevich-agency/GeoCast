# ---- shared ----
APP_ENV=dev

# ---- web (apps/web) ----
# Public — baked into the JS bundle
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ---- api (apps/api) ----
APP_SECRET=change-me-32-chars-of-randomness
DATABASE_URL="mysql://geocast:geocast@db:3306/geocast?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
REDIS_URL=redis://redis:6379

# JWT (LexikJWTAuthenticationBundle)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me
JWT_TTL=86400

# Pusher (server)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# CORS — comma-separated origins allowed to call the API
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Admin bootstrap — wallet addresses (lowercase, comma-separated) that get is_admin=true on first login
ADMIN_WALLETS=

# SIWE — comma-separated chain IDs accepted at sign-in (1=mainnet, 8453=Base, 137=Polygon)
SIWE_ALLOWED_CHAIN_IDS=1,8453,137
